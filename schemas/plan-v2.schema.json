{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/woogi-kang/craft-harness/schemas/plan-v2.schema.json",
  "title": "Craft Harness Plan v2",
  "type": "object",
  "required": ["session", "workers"],
  "additionalProperties": true,
  "properties": {
    "session": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 _-]{0,63}$"
    },
    "base_ref": {
      "type": "string",
      "default": "HEAD"
    },
    "launcher": {
      "type": "string"
    },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/worker"
      }
    }
  },
  "$defs": {
    "worker": {
      "type": "object",
      "required": ["name", "task"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "eval_type": {
          "type": "string",
          "enum": ["", "api", "ui", "fullstack", "content", "review", "custom"],
          "default": ""
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
